# Runtime source for the React app.
# api  = Rust/Axum backend at /api (default for app development)
# mock = local fake runtime, useful for future marketing/preview site
VITE_VESSELIX_RUNTIME=api

# Optional override if the frontend is not served by Vite proxy.
# VITE_VESSELIX_API_BASE_URL=http://127.0.0.1:8787
